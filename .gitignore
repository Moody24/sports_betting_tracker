# Ignore virtual environment folder
venv/
.venv/

# Ignore environment variables file at root (sensitive data)
.env
.env.backup

# Ignore SQLite database file (optional, only if you don't want to track it)
app/database.db

# Ignore Python bytecode files
__pycache__/
*.pyc

# Ignore macOS system files
.DS_Store

instance/app.db

# Coverage reports
.coverage
htmlcov/

# ML model artifacts — stored on S3 in production, not tracked in git
app/ml_models/*.json
app/ml_models/*.pkl

# Local Python 3.10 venv created for dev
venv310/

instance.bak/
tests/helpers.py.backup
