# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-strong-secret-key-here

# Database — defaults to SQLite for local dev; set a postgres:// URL for production
DATABASE_URL=sqlite:///app.db

# The Odds API — https://the-odds-api.com (free tier available)
# Required for live over/under lines and player props on the NBA Today page
ODDS_API_KEY=your-odds-api-key-here

# Set to "true" only during local development — never in production
FLASK_DEBUG=false
