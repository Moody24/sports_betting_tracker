# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Required ─────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-strong-secret-key-here

# ── Database (Neon Postgres) ─────────────────────────────────────────
# Use your Neon connection string (pooled endpoint recommended):
#   DATABASE_URL=postgresql://user:password@ep-xyz-123.us-east-2.aws.neon.tech/dbname?sslmode=require
#
# In Railway: add Neon connection string as DATABASE_URL in the service variables.
# Do NOT add a Railway Postgres plugin — Neon is the database.
DATABASE_URL=postgresql://user:password@ep-xyz-123.us-east-2.aws.neon.tech/dbname?sslmode=require

# ── The Odds API ─────────────────────────────────────────────────────
# https://the-odds-api.com (free tier available)
# Required for live over/under lines and player props on the NBA Today page
ODDS_API_KEY=your-odds-api-key-here

# ── Flask / Gunicorn ─────────────────────────────────────────────────
# Set to "true" only during local development — never in production
FLASK_DEBUG=false

# Gunicorn worker count — keep at 2 on Railway hobby tier (512MB RAM)
WEB_CONCURRENCY=2

# ── Scheduler ────────────────────────────────────────────────────────
# Set to "true" in Railway web service to enable the APScheduler background jobs.
# Set to "false" locally and during migrations to avoid starting the scheduler.
SCHEDULER_ENABLED=false


# ── Database connection pool (PostgreSQL only) ───────────────────────
# pool_size and max_overflow are skipped for SQLite (tests use sqlite:///:memory:).
# Tune on Railway if you see "QueuePool limit of size N overflow N reached".
DB_POOL_SIZE=2
DB_MAX_OVERFLOW=3

# ── Auto-pick thresholds ─────────────────────────────────────────────
# Maximum auto-generated bets per daily run
AUTO_PICK_MAX_TOTAL=50
# Minimum edge required for a straight (1-leg) auto pick
AUTO_PICK_MIN_EDGE_STRAIGHT=0.15
# Minimum edge per leg for a 2-leg parlay auto pick
AUTO_PICK_MIN_EDGE_2LEG=0.15
# Minimum edge per leg for a 3-leg parlay auto pick
AUTO_PICK_MIN_EDGE_3LEG=0.15
# Minimum career games before a player is eligible for auto picks
AUTO_PICK_MIN_GAMES=15
# Minimum Model 2 confidence tier: "strong" | "medium" | "any"
AUTO_PICK_CONFIDENCE_TIER=strong

# ── Market recommender thresholds (moneyline / totals) ───────────────
# Override the trained-model thresholds at runtime without retraining.
# Leave blank to use the values stored in ModelMetadata (or fallback defaults).
MARKET_REC_MIN_EDGE_ML=
MARKET_REC_MIN_CONF_ML=
MARKET_REC_MIN_EDGE_TOTAL=
MARKET_REC_MIN_CONF_TOTAL=

# Kill-switches — set to "false" to disable a market recommendation entirely
MONEYLINE_RECS_ENABLED=true
TOTAL_RECS_ENABLED=true

# ── Model Storage (AWS S3 for retrained artifacts) ──────────────────
# Use local storage by default, or set MODEL_STORAGE=s3 to persist model
# artifacts to an S3 bucket.
MODEL_STORAGE=local
S3_MODEL_BUCKET=
S3_MODEL_PREFIX=models/
AWS_REGION=
