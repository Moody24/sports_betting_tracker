# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-strong-secret-key-here

# Database — defaults to SQLite for local dev; set a postgres:// URL for production
# Railway provides this automatically via: ${{Postgres.DATABASE_URL}}
# Local SQLite (default):
DATABASE_URL=sqlite:///app.db
# Production Postgres example:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# The Odds API — https://the-odds-api.com (free tier available)
# Required for live over/under lines and player props on the NBA Today page
ODDS_API_KEY=your-odds-api-key-here

# Set to "true" only during local development — never in production
FLASK_DEBUG=false

# Gunicorn worker count — keep at 2 on Railway hobby tier (512MB RAM)
WEB_CONCURRENCY=2

# Set to "true" in Railway web service to enable the APScheduler background jobs.
# Set to "false" locally and during migrations to avoid starting the scheduler.
SCHEDULER_ENABLED=false
