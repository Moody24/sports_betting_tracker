# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Required ─────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-strong-secret-key-here

# ── Database ──────────────────────────────────────────────────────────
# Local development (SQLite — no setup required):
DATABASE_URL=sqlite:///instance/app.db

# PostgreSQL (when connecting to a hosted DB like Neon):
#   DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
#
# Note: "postgres://" URLs are automatically rewritten to "postgresql://"
# for SQLAlchemy compatibility.

# ── The Odds API ─────────────────────────────────────────────────────
# https://the-odds-api.com (free tier available)
# Required for live over/under lines and player props on the NBA Today page.
# Without it, the app still runs — live odds pages degrade gracefully.
ODDS_API_KEY=your-odds-api-key-here

# ── Flask ─────────────────────────────────────────────────────────────
# Set to "true" for local development
FLASK_DEBUG=true

# ── Scheduler ────────────────────────────────────────────────────────
# Keep "false" locally — trigger jobs manually via Flask CLI commands.
# Set to "true" only on a dedicated scheduler process (e.g. Railway service).
SCHEDULER_ENABLED=false

# ── Database connection pool (PostgreSQL only) ───────────────────────
# These are ignored for SQLite. Tune when connecting to PostgreSQL if you
# see "QueuePool limit of size N overflow N reached".
DB_POOL_SIZE=2
DB_MAX_OVERFLOW=3

# ── Auto-pick thresholds ─────────────────────────────────────────────
# Maximum auto-generated bets per daily run
AUTO_PICK_MAX_TOTAL=50
# Minimum edge required for a straight (1-leg) auto pick
AUTO_PICK_MIN_EDGE_STRAIGHT=0.15
# Minimum edge per leg for a 2-leg parlay auto pick
AUTO_PICK_MIN_EDGE_2LEG=0.15
# Minimum edge per leg for a 3-leg parlay auto pick
AUTO_PICK_MIN_EDGE_3LEG=0.15
# Minimum career games before a player is eligible for auto picks
AUTO_PICK_MIN_GAMES=15
# Minimum Model 2 confidence tier: "strong" | "medium" | "any"
AUTO_PICK_CONFIDENCE_TIER=strong

# ── Market recommender thresholds (moneyline / totals) ───────────────
# Leave blank to use the values stored in ModelMetadata (or fallback defaults).
MARKET_REC_MIN_EDGE_ML=
MARKET_REC_MIN_CONF_ML=
MARKET_REC_MIN_EDGE_TOTAL=
MARKET_REC_MIN_CONF_TOTAL=

# Kill-switches — set to "false" to disable a market type entirely
MONEYLINE_RECS_ENABLED=true
TOTAL_RECS_ENABLED=true

# ── Model Storage ────────────────────────────────────────────────────
# "local" stores model artifacts in app/ml_models/ (gitignored).
# "s3" stores them in AWS S3 (requires S3 vars below).
MODEL_STORAGE=local

# S3 vars (only needed if MODEL_STORAGE=s3):
S3_MODEL_BUCKET=
S3_MODEL_PREFIX=models/
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Rate limiting — required for multi-worker production (gunicorn WEB_CONCURRENCY > 1)
# Without this, each worker has isolated counters and effective rate limits are multiplied
# RATELIMIT_STORAGE_URI=redis://localhost:6379/0

# ── Gunicorn (production only) ────────────────────────────────────────
# Keep at 2 workers on low-memory hosts (512MB RAM)
WEB_CONCURRENCY=2
